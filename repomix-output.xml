            word-break: break-all;
            font-family: monospace;
            font-size: 0.85rem;
            color: #22c55e;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .copy-btn {
            background: #0ea5e9;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.8rem;
            white-space: nowrap;
            margin-left: 8px;
        }

        .copy-btn:hover {
            background: #06b6d4;
        }

        .input-section {
            background: #0f172a;
            padding: 15px;
            border-radius: 10px;
            border: 2px solid #f59e0b;
            grid-column: 1 / -1;
        }

        .input-section h3 {
            color: #f59e0b;
            margin-top: 0;
            margin-bottom: 12px;
            font-size: 0.95rem;
        }

        .input-section p {
            color: #cbd5e1;
            margin: 0 0 12px 0;
            font-size: 0.9rem;
        }

        input[type="text"] {
            padding: 12px;
            border-radius: 6px;
            border: 2px solid #0ea5e9;

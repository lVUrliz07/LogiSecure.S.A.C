<body>
    <div class="dashboard-container">
        <div class="top-bar">
            <div class="user-info">
                <h1 style="color: var(--primary-blue); margin: 0;">🚚 LogiSecure</h1>
                <span class="role-badge" id="userRoleBadge">ROL</span>
            </div>
            <div>
                <span class="user-name" id="userName"></span>
                <button class="btn-small" onclick="window.location.href='/setup-2fa'">🔐 2FA</button>
                <button class="logout-btn" onclick="logout()">Cerrar Sesión</button>
            </div>
        </div>

        <!-- Pestañas de Navegación -->
        <div style="background: var(--white); padding: 0; border-radius: 15px 15px 0 0; box-shadow: 0 4px 20px rgba(30, 58, 138, 0.1); margin-bottom: 0; display: flex; flex-wrap: wrap; border-bottom: 2px solid #e5e7eb;">
            <button class="nav-tab active-tab" onclick="switchTab(event, 'rutas')">🛣️ Rutas</button>
            <button class="nav-tab" id="usersTabBtn" onclick="switchTab(event, 'usuarios')" style="display: none;">👥 Usuarios</button>
            <button class="nav-tab" id="codesTabBtn" onclick="switchTab(event, 'codigos')" style="display: none;">🔐 Códigos</button>
            <button class="nav-tab" id="statsTabBtn" onclick="switchTab(event, 'estadisticas')" style="display: none;">📊 Estadísticas</button>
            <button class="nav-tab" id="sensibleTabBtn" onclick="switchTab(event, 'sensibles')" style="display: none;">⚠️ Datos Sensibles</button>
        </div>

        <!-- TAB: RUTAS -->
        <div id="tab-rutas" class="tab-content active">
            <div class="cards-grid">
                <div class="card" id="createRouteCar" style="display: none;">
                    <h3>➕ Nueva Ruta</h3>
                    <div id="choferWarning" style="color: #f59e0b; padding: 10px; background: #fef3c7; border-radius: 8px; margin-bottom: 15px; display: none;">
                        <strong>⚠️ Primero debes crear choferes en la tab "Usuarios"</strong>
                    </div>
                    <form onsubmit="createRoute(event)">
                        <div class="form-group">
                            <label>Chofer *</label>
                            <select id="choferSelect" required>
                                <option value="">Cargando choferes...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Origen *</label>
                            <input type="text" id="routeOrigen" placeholder="Ej: Ciudad de México" required>
                        </div>
                        <div class="form-group">
                            <label>Destino *</label>
                            <input type="text" id="routeDestino" placeholder="Ej: Guadalajara" required>
                        </div>
                        <div class="form-group">
                            <label>Descripción</label>
                            <input type="text" id="routeDescripcion" placeholder="Entrega de mercancía">
                        </div>
                        <div class="form-group">
                            <label>Distancia (km) *</label>
                            <input type="number" id="routeDistancia" placeholder="550.5" step="0.1" required>
                        </div>
                        <div id="routeMessage" class="alert hidden"></div>
                        <button type="submit" class="btn-small" style="width: 100%; background: var(--success);">Crear Ruta</button>
                    </form>
                </div>
            </div>
            
            <div class="card">
                <h3>📋 Listado de Rutas</h3>
                <div id="routesContent">Cargando...</div>
            </div>
        </div>

        <!-- TAB: USUARIOS -->
        <div id="tab-usuarios" class="tab-content">
            <div class="cards-grid">
                <div class="card">
                    <h3>➕ Nuevo Usuario</h3>
                    <p style="color: #f59e0b; padding: 10px; background: #fef3c7; border-radius: 8px; margin-bottom: 15px;"><strong>🔒 Solo el GERENTE puede crear usuarios</strong></p>
                    <form onsubmit="createUser(event)">
                        <div class="form-group">
                            <label>Email *</label>
                            <input type="email" id="userEmail" placeholder="usuario@logisecure.com" required>
                        </div>
                        <div class="form-group">
                            <label>Usuario *</label>
                            <input type="text" id="userUsername" placeholder="usuario123" required>
                        </div>
                        <div class="form-group">
                            <label>Nombre Completo *</label>
                            <input type="text" id="userFullName" placeholder="Juan Pérez García" required>
                        </div>
                        <div class="form-group">
                            <label>Contraseña *</label>
                            <input type="password" id="userPassword" placeholder="••••••••" required>
                        </div>
                        <div class="form-group">
                            <label>Rol *</label>
                            <select id="userRole" required>
                                <option value="">Seleccionar rol...</option>
                                <option value="CHOFER">Chofer</option>
                                <option value="DISPATCHER">Dispatcher</option>
                                <option value="GERENTE">Gerente</option>
                            </select>
                        </div>
                        <div id="userMessage" class="alert hidden"></div>
                        <button type="submit" class="btn-small" style="width: 100%; background: var(--success);">Crear Usuario</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <h3>👥 Listado de Usuarios</h3>
                <div id="usersContent">Cargando...</div>
            </div>
        </div>

        <!-- TAB: CÓDIGOS TEMPORALES -->
        <div id="tab-codigos" class="tab-content">
            <div class="cards-grid">
                <div class="card">
                    <h3>🔑 Generar Código Temporal</h3>
                    <form onsubmit="generateCode(event)">
                        <div class="form-group">
                            <label>Propósito *</label>
                            <input type="text" id="codePurpose" placeholder="Ej: Combustible extra en ruta" required>
                        </div>
                        <div id="codeMessage" class="alert hidden"></div>
                        <div id="codeDisplay" class="code-display hidden"></div>
                        <button type="submit" class="btn-small" style="width: 100%; background: var(--success);">Generar Código</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <h3>📌 Códigos Activos</h3>
                <div id="codesContent">Cargando...</div>
            </div>
        </div>

        <!-- TAB: ESTADÍSTICAS -->
        <div id="tab-estadisticas" class="tab-content">
            <div class="card">
                <h3>📊 Estadísticas del Sistema</h3>
                <div id="statsContent">Cargando...</div>
            </div>
        </div>

        <!-- TAB: DATOS SENSIBLES -->
        <div id="tab-sensibles" class="tab-content">
            <div class="card">
                <h3>🔐 Datos Confidenciales</h3>
                <button class="btn-small" onclick="loadSensitiveData()">Cargar Datos</button>
                <div id="sensitiveContent"></div>
            </div>
        </div>
    </div>

    <script>
        const API_URL = 'http://localhost:8000';
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        
        if (!token) {
            window.location.href = '/login';
        } else if (!user.is_totp_enabled) {
            window.location.href = '/setup-2fa';
        }
        
        document.getElementById('userName').textContent = user.full_name;
        document.getElementById('userRoleBadge').textContent = user.role;
        console.log("Debug - Usuario logueado:", user);

        // Mostrar pestañas según el rol
        const role = String(user.role || '').toUpperCase();
        
        if (role.includes('GERENTE')) {
            document.getElementById('usersTabBtn').style.display = 'block';
            document.getElementById('codesTabBtn').style.display = 'block';
            document.getElementById('statsTabBtn').style.display = 'block';
            document.getElementById('sensibleTabBtn').style.display = 'block';
            document.getElementById('createRouteCar').style.display = 'block';
        } else if (role.includes('DISPATCHER')) {
            document.getElementById('statsTabBtn').style.display = 'block';
            document.getElementById('createRouteCar').style.display = 'block';
        }
        
        // Cargar datos iniciales
        loadRoutes();
        
        const currentRole = String(user.role || '').toUpperCase();
        if (currentRole.includes('GERENTE') || currentRole.includes('DISPATCHER')) {
            loadChoferes();
        }

        // FUNCIONES DE NAVEGACIÓN
        function switchTab(e, tabName) {
            // Ocultar todos los tabs
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(btn => btn.classList.remove('active-tab'));
            
            // Mostrar tab seleccionado
            const targetTab = document.getElementById(`tab-${tabName}`);
            if (targetTab) {
                targetTab.classList.add('active');
            }
            
            // Marcar botón activo (e.currentTarget es el botón, e.target podría ser el icono)
            if (e && e.currentTarget) {
                e.currentTarget.classList.add('active-tab');
            } else if (e && e.target) {
                // Fallback si no viene de un evento directo
                e.target.closest('.nav-tab')?.classList.add('active-tab');
            }
            
            // Cargar datos
            if (tabName === 'usuarios') {
                loadUsers();
            } else if (tabName === 'codigos') {
                loadCodes();
            } else if (tabName === 'estadisticas') {
                loadStats();
            }
        }
        
        let totalKmChofer = 0;

        // RUTAS
        async function loadRoutes() {
            try {
                const endpoint = user.role === 'CHOFER' ? '/routes/my-routes' : '/routes/';
                const response = await fetch(`${API_URL}${endpoint}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const routes = await response.json();
                
                if (!Array.isArray(routes) || routes.length === 0) {
                    document.getElementById('routesContent').innerHTML = '<p style="text-align: center; color: #9ca3af;">No hay rutas disponibles</p>';
                    return;
                }
                
                const role = String(user.role || '').toUpperCase();
                let html = `<table class="routes-table"><thead><tr><th>ID</th><th>Origen</th><th>Destino</th><th>Descripción</th><th>Estado</th><th>Distancia</th>${role.includes('CHOFER') || role.includes('GERENTE') || role.includes('DISPATCHER') ? '<th>Acciones</th>' : ''}</tr></thead><tbody>`;
                totalKmChofer = 0;
                routes.forEach(ruta => {
                    let actionsHtml = '';
                    if (role.includes('CHOFER')) {
                        totalKmChofer += ruta.distancia_km || 0;
                        if (ruta.estado === 'pendiente') {
                            actionsHtml = `<td><button class="btn-small" onclick="updateRouteStatus(${ruta.id}, 'en_progreso')" style="padding: 5px 10px; font-size: 0.8rem;">▶️ Iniciar</button></td>`;
                        } else if (ruta.estado === 'en_progreso') {
                            actionsHtml = `<td><button class="btn-small" onclick="updateRouteStatus(${ruta.id}, 'completada')" style="padding: 5px 10px; font-size: 0.8rem; background: var(--success);">✅ Finalizar</button></td>`;
                        }
                    } else if (role.includes('GERENTE') || role.includes('DISPATCHER')) {
                        actionsHtml = `<td><button class="btn-small" onclick="deleteRoute(${ruta.id})" style="padding: 5px 10px; font-size: 0.8rem; background: var(--error);">🗑️</button></td>`;
                    }

                    html += `<tr>
                        <td>#${ruta.id}</td>
                        <td>${ruta.origen}</td>
                        <td>${ruta.destino}</td>
                        <td>${ruta.descripcion || '-'}</td>
                        <td><span class="status-badge status-${ruta.estado || 'pendiente'}">${ruta.estado || 'pendiente'}</span></td>
                        <td>${ruta.distancia_km ? ruta.distancia_km + ' km' : '-'}</td>
                        ${actionsHtml}
                    </tr>`;
                });
                html += '</tbody></table>';
                
                if (user.role === 'CHOFER') {
                    html = `<div class="card" style="margin-bottom: 20px; background: var(--primary-blue); color: white;">
                                <h4 style="margin:0">📊 Mi Resumen: <span style="color: var(--turquoise)">${totalKmChofer.toFixed(1)} km</span> recorridos en total</h4>
                            </div>` + html;
                }
                
                document.getElementById('routesContent').innerHTML = html;
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('routesContent').innerHTML = '<p style="color: var(--error);">Error al cargar rutas</p>';
            }
        }

        async function loadChoferes() {
            try {
                const response = await fetch(`${API_URL}/users/`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!response.ok) {
                    console.log('No se pudieron cargar choferes:', response.status);
                    const select = document.getElementById('choferSelect');
                    select.innerHTML = '<option value="">⚠️ Error al cargar choferes</option>';
                    document.getElementById('choferWarning').style.display = 'block';
                    return;
                }

                const users = await response.json();
                const choferes = users.filter(u => u.role === 'CHOFER');
                
                const select = document.getElementById('choferSelect');
                select.innerHTML = '';
                
                if (choferes.length === 0) {
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = '⚠️ No hay choferes disponibles';
                    option.disabled = true;
                    option.selected = true;
                    select.appendChild(option);
                    document.getElementById('choferWarning').style.display = 'block';
                    select.disabled = true;
                } else {
                    const optionDefault = document.createElement('option');
                    optionDefault.value = '';
                    optionDefault.textContent = '📌 Seleccionar chofer...';
                    select.appendChild(optionDefault);
                    
                    choferes.forEach(chofer => {
                        const option = document.createElement('option');
                        option.value = chofer.id;
                        option.textContent = `👨‍✈️ ${chofer.full_name} (${chofer.email})`;
                        select.appendChild(option);
                    });
                    document.getElementById('choferWarning').style.display = 'none';
                    select.disabled = false;
                }
            } catch (error) {
                console.error('Error cargando choferes:', error);
                const select = document.getElementById('choferSelect');
                select.innerHTML = '<option value="">❌ Error al cargar choferes</option>';
            }
        }

        async function createRoute(event) {
            event.preventDefault();
            
            const routeData = {
                chofer_id: parseInt(document.getElementById('choferSelect').value),
                origen: document.getElementById('routeOrigen').value,
                destino: document.getElementById('routeDestino').value,
                descripcion: document.getElementById('routeDescripcion').value,
                distancia_km: parseFloat(document.getElementById('routeDistancia').value)
            };

            try {
                const response = await fetch(`${API_URL}/routes/`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(routeData)
                });

                const messageDiv = document.getElementById('routeMessage');
                
                if (response.ok) {
                    messageDiv.className = 'alert alert-success show';
                    messageDiv.textContent = '✓ Ruta creada exitosamente';
                    event.target.reset();
                    setTimeout(() => {
                        messageDiv.classList.remove('show');
                        loadRoutes();
                    }, 2000);
                } else {
                    const error = await response.json();
                    messageDiv.className = 'alert alert-error show';
                    messageDiv.textContent = '✗ ' + (error.detail || 'Error al crear ruta');
                }
            } catch (error) {
                document.getElementById('routeMessage').className = 'alert alert-error show';
                document.getElementById('routeMessage').textContent = '✗ Error: ' + error.message;
            }
        }

        async function updateRouteStatus(rutaId, nuevoEstado) {
            try {
                const response = await fetch(`${API_URL}/routes/${rutaId}/status?estado=${nuevoEstado}`, {
                    method: 'PUT',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.ok) {
                    loadRoutes();
                    const role = String(user.role || '').toUpperCase();
                    if (role.includes('GERENTE') || role.includes('DISPATCHER')) {
                        loadStats();
                    }
                } else {
                    const error = await response.json();
                    alert('Error: ' + (error.detail || 'No se pudo actualizar el estado'));
                }
            } catch (error) {
                alert('Error de conexión');
            }
        }

        async function deleteRoute(rutaId) {
            if (!confirm('¿Estás seguro de eliminar esta ruta?')) return;
            try {
                const response = await fetch(`${API_URL}/routes/${rutaId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (response.ok) {
                    loadRoutes();
                    loadStats();
                }
            } catch (error) { alert('Error al eliminar'); }
        }

        // USUARIOS
        async function loadUsers() {
            try {
                const response = await fetch(`${API_URL}/users/`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const users = await response.json();
                
                if (!Array.isArray(users) || users.length === 0) {
                    document.getElementById('usersContent').innerHTML = '<p>No hay usuarios</p>';
                    return;
                }
                
                let html = '<table class="users-table"><thead><tr><th>ID</th><th>Email</th><th>Usuario</th><th>Nombre</th><th>Rol</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>';
                users.forEach(u => {
                    const deleteBtn = u.id !== user.id ? `<button class="btn-small" onclick="deleteUser(${u.id})" style="padding: 5px 10px; font-size: 0.8rem; background: var(--error);">🗑️ Desactivar</button>` : '-';
                    html += `<tr>
                        <td>#${u.id}</td>
                        <td>${u.email}</td>
                        <td>${u.username}</td>
                        <td>${u.full_name}</td>
                        <td><span class="status-badge" style="background: var(--light-blue); color: white;">${u.role}</span></td>
                        <td>${u.is_active ? '✓ Activo' : '✗ Inactivo'}</td>
                        <td>${deleteBtn}</td>
                    </tr>`;
                });
                html += '</tbody></table>';
                document.getElementById('usersContent').innerHTML = html;
            } catch (error) {
                document.getElementById('usersContent').textContent = 'Error al cargar usuarios';
            }
        }

        async function deleteUser(userId) {
            if (!confirm('¿Estás seguro de desactivar este usuario?')) return;
            try {
                const response = await fetch(`${API_URL}/users/${userId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (response.ok) { loadUsers(); loadStats(); }
            } catch (error) { alert('Error al procesar'); }
        }

        async function createUser(event) {
            event.preventDefault();
            
            const userData = {
                email: document.getElementById('userEmail').value,
                username: document.getElementById('userUsername').value,
                full_name: document.getElementById('userFullName').value,
                password: document.getElementById('userPassword').value,
                role: document.getElementById('userRole').value
            };

            try {
                const response = await fetch(`${API_URL}/users/`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(userData)
                });

                const messageDiv = document.getElementById('userMessage');
                
                if (response.ok) {
                    messageDiv.className = 'alert alert-success show';
                    messageDiv.textContent = '✓ Usuario creado exitosamente';
                    event.target.reset();
                    setTimeout(() => {
                        messageDiv.classList.remove('show');
                        loadUsers();
                    }, 2000);
                } else {
                    const error = await response.json();
                    messageDiv.className = 'alert alert-error show';
                    messageDiv.textContent = '✗ ' + (error.detail || 'Error al crear usuario');
                }
            } catch (error) {
                document.getElementById('userMessage').className = 'alert alert-error show';
                document.getElementById('userMessage').textContent = '✗ Error: ' + error.message;
            }
        }

        // CÓDIGOS TEMPORALES
        async function generateCode(event) {
            event.preventDefault();
            
            const codeData = {
                purpose: document.getElementById('codePurpose').value
            };

            try {
                const response = await fetch(`${API_URL}/auth/generate-code`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(codeData)
                });

                const messageDiv = document.getElementById('codeMessage');
                const codeDisplay = document.getElementById('codeDisplay');
                
                if (response.ok) {
                    const result = await response.json();
                    messageDiv.className = 'alert alert-success show';
                    messageDiv.textContent = '✓ Código generado exitosamente';
                    codeDisplay.textContent = result.code;
                    codeDisplay.classList.remove('hidden');
                    event.target.reset();
                    setTimeout(() => {
                        loadCodes();
                    }, 2000);
                } else {
                    const error = await response.json();
                    messageDiv.className = 'alert alert-error show';
                    messageDiv.textContent = '✗ ' + (error.detail || 'Error al generar código');
                    codeDisplay.classList.add('hidden');
                }
            } catch (error) {
                document.getElementById('codeMessage').className = 'alert alert-error show';
                document.getElementById('codeMessage').textContent = '✗ Error: ' + error.message;
            }
        }

        async function loadCodes() {
            try {
                const response = await fetch(`${API_URL}/gerente/codes`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!response.ok) {
                    throw new Error('Error al cargar códigos');
                }

                const codes = await response.json();
                
                if (!Array.isArray(codes) || codes.length === 0) {
                    document.getElementById('codesContent').innerHTML = '<p style="text-align: center; color: #9ca3af;">📭 No hay códigos generados aún. Crea uno con el formulario arriba.</p>';
                    return;
                }
                
                let html = '<table class="routes-table"><thead><tr><th>Código</th><th>Propósito</th><th>Estado</th><th>Expira</th></tr></thead><tbody>';
                codes.forEach(c => {
                    const used = c.is_used ? '<span class="status-badge" style="background: #ef4444; color: white;">Usado</span>' : '<span class="status-badge" style="background: #22c55e; color: white;">✓ Activo</span>';
                    const expireDate = new Date(c.expires_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' });
                    const expireTime = new Date(c.expires_at).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
                    html += `<tr>
                        <td><strong style="font-size: 1.4rem; color: var(--turquoise);">${c.code}</strong></td>
                        <td>${c.purpose}</td>
                        <td>${used}</td>
                        <td>${expireDate} ${expireTime}</td>
                    </tr>`;
                });
                html += '</tbody></table>';
                document.getElementById('codesContent').innerHTML = html;
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('codesContent').innerHTML = '<p style="text-align: center; color: #9ca3af;">📭 No hay códigos disponibles</p>';
            }
        }

        // ESTADÍSTICAS
        async function loadStats() {
            try {
                const response = await fetch(`${API_URL}/gerente/stats`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!response.ok) {
                    throw new Error('Error al cargar estadísticas');
                }

                const stats = await response.json();
                
                document.getElementById('statsContent').innerHTML = `
                    <div class="cards-grid">
                        <div class="card" style="border-left: 4px solid var(--turquoise);">
                            <div class="data-item"><strong>👤 Choferes:</strong> <span style="font-size: 1.3rem; color: var(--turquoise);">${stats.total_choferes}</span></div>
                            <div class="data-item"><strong>📋 Dispatchers:</strong> <span style="font-size: 1.3rem; color: var(--turquoise);">${stats.total_dispatchers}</span></div>
                        </div>
                        <div class="card" style="border-left: 4px solid var(--light-blue);">
                            <div class="data-item"><strong>🚚 Total Rutas:</strong> <span style="font-size: 1.3rem; color: var(--light-blue);">${stats.total_rutas}</span></div>
                            <div class="data-item"><strong>⏳ Rutas Activas:</strong> <span style="font-size: 1.3rem; color: #fbbf24;">${stats.rutas_activas}</span></div>
                            <div class="data-item"><strong>✓ Rutas Completadas:</strong> <span style="font-size: 1.3rem; color: #22c55e;">${stats.rutas_completadas}</span></div>
                        </div>
                    </div>
                `;
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('statsContent').innerHTML = '<p style="text-align: center; color: #9ca3af;">📊 Las estadísticas aparecerán una vez que haya datos</p>';
            }
        }
        
        async function loadSensitiveData() {
            try {
                const response = await fetch(`${API_URL}/gerente/sensitive-data`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!response.ok) {
                    throw new Error('Error al cargar datos sensibles');
                }

                const data = await response.json();
                
                document.getElementById('sensitiveContent').innerHTML = `
                    <div class="data-item sensitive-data">
                        <strong>💰 Costo Real:</strong> $${data.costo_real}<br>
                        <strong>📈 Margen de Ganancia:</strong> ${data.margen_ganancia}%<br>
                        <strong>⭐ Clientes VIP:</strong> ${data.clientes_vip.join(', ')}<br>
                        <strong>⛽ Combustible Extra:</strong> ${data.combustible_extra_en_ruta ? 'Sí ✓' : 'No'}<br>
                        <strong>📝 Notas:</strong> ${data.notas_confidenciales}
                    </div>
                `;
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('sensitiveContent').innerHTML = '<p style="color: var(--error);">⚠️ Error al cargar datos confidenciales</p>';
            }
        }

        function logout() {
            localStorage.clear();
            window.location.href = '/login';
        }
    </script>
</body>
</html>
</file>

<file path="app/templates/login.html">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LogiSecure - Login</title>
    <link rel="stylesheet" href="{{ url_for('static', path='style.css') }}">
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
            background: var(--white);
        }
        
        .login-split {
            display: flex;
            width: 100%;
            height: 100vh;
        }
        
        .login-form-side {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, var(--light-blue) 0%, var(--light-turquoise) 100%);
            padding: 20px;
        }
        
        .login-carousel-side {
            flex: 1;
            position: relative;
            overflow: hidden;
        }
        
        .carousel-item {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            animation: crossfade 15s infinite;
        }
        
        .carousel-item:nth-child(1) { animation-delay: 0s; }
        .carousel-item:nth-child(2) { animation-delay: 5s; }
        .carousel-item:nth-child(3) { animation-delay: 10s; }
        
        @keyframes crossfade {
            0% { opacity: 0; transform: scale(1.05); }
            10% { opacity: 1; transform: scale(1); }
            33% { opacity: 1; transform: scale(1); }
            43% { opacity: 0; transform: scale(1.05); }
            100% { opacity: 0; }
        }
        
        @media (max-width: 900px) {
            .login-carousel-side {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="login-split">
        <div class="login-form-side">
            <div class="container">
        <div class="header">
            <h1>🚚 LogiSecure</h1>
            <p>Sistema de Gestión Logística</p>
        </div>
        
        <div class="content">
            <div id="alert" class="alert hidden"></div>
            
            <form id="loginForm">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com">
                </div>
                
                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" required placeholder="••••••••">
                </div>

                <div class="form-group" id="totpGroup" style="display:none;">
                    <label for="totp">Código 2FA (Google Authenticator)</label>
                    <input type="text" id="totp" name="totp" placeholder="123456" maxlength="6">
                </div>
                
                <button type="submit" class="btn" id="submitBtn">Iniciar Sesión</button>
            </form>
            
            <div class="divider">o</div>
            
            <button class="btn btn-google" id="googleBtn" type="button">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google Logo">
                Continuar con Google
            </button>
            
            <div class="link">
                <p>¿No tienes cuenta? <a href="/register">Regístrate</a></p>
            </div>
        </div>
    </div>
        </div>
        <div class="login-carousel-side">
            <img src="{{ url_for('static', path='bg-carousel-1.png') }}" class="carousel-item" alt="Logistics Flow 1">
            <img src="{{ url_for('static', path='bg-carousel-2.png') }}" class="carousel-item" alt="Logistics Warehouse">
            <img src="{{ url_for('static', path='bg-carousel-3.png') }}" class="carousel-item" alt="Global Network">
        </div>
    </div>

    <script>
        const API_URL = 'http://localhost:8000';
        
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const btn = document.getElementById('submitBtn');
            const alert = document.getElementById('alert');
            
            btn.disabled = true;
            btn.textContent = 'Iniciando...';
            
            const data = {
                email: document.getElementById('email').value,
                password: document.getElementById('password').value
            };
            
            const totpVal = document.getElementById('totp').value;
            if (totpVal) {
                data.totp_code = totpVal;
            }
            
            try {
                const response = await fetch(`${API_URL}/auth/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    localStorage.setItem('token', result.access_token);
                    localStorage.setItem('user', JSON.stringify(result.user));
                    if (result.user && !result.user.is_totp_enabled) {
                        window.location.href = '/setup-2fa';
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    if (result.detail === 'Código 2FA requerido') {
                        document.getElementById('totpGroup').style.display = 'block';
                        document.getElementById('totp').required = true;
                        document.getElementById('totp').focus();
                        alert.innerHTML = '<strong>🔐 2FA Activado</strong><br>Por favor ingresa el código de 6 dígitos de tu Google Authenticator';
                        alert.className = 'alert alert-error';
                        alert.classList.remove('hidden');
                    } else if (result.detail === 'Código 2FA inválido') {
                        alert.textContent = '❌ Código 2FA incorrecto. Verifica que ingresaste el código correcto de Google Authenticator';
                        alert.className = 'alert alert-error';
                        alert.classList.remove('hidden');
                        document.getElementById('totp').value = '';
                        document.getElementById('totp').focus();
                    } else {
                        alert.textContent = result.detail || 'Error al iniciar sesión';
                        alert.className = 'alert alert-error';
                        alert.classList.remove('hidden');
                    }
                }
            } catch (error) {
                alert.textContent = 'Error de conexión';
                alert.className = 'alert alert-error';
                alert.classList.remove('hidden');
            }
            
            btn.disabled = false;
            btn.textContent = 'Iniciar Sesión';
        });
        
        if (localStorage.getItem('token')) {
            const user = JSON.parse(localStorage.getItem('user') || '{}');
            if (user && !user.is_totp_enabled) {
                window.location.href = '/setup-2fa';
            } else {
                window.location.href = '/dashboard';
            }
        }
        
        // Lógica para Google Login
        document.getElementById('googleBtn').addEventListener('click', () => {
            // Aquí se integraría el SDK de Google Identity Services (GSI)
            // Una vez obtenido el token de Google, se enviaría al backend:
            // fetch(`${API_URL}/auth/google`, { method: 'POST', body: JSON.stringify({ token: '...' }) })
            console.log('Botón de Google clickeado. Requiere inicializar el SDK de Google.');
            alert('Esta es la interfaz funcional. Para que Google inicie sesión, debes agregar el Client ID proporcionado por Google Cloud Console en el archivo .env e inicializar el script de Google (GSI). ¡El backend (google_auth.py) ya está listo para recibir el token!');
        });
    </script>
</body>
</html>
</file>

<file path="app/templates/register.html">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LogiSecure - Registro</title>
    <link rel="stylesheet" href="{{ url_for('static', path='style.css') }}">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>LogiSecure</h1>
            <p>Crear Cuenta</p>
        </div>
        
        <div class="content">
            <div id="alert" class="alert hidden"></div>
            
            <form id="registerForm">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com">
                </div>
                
                <div class="form-group">
                    <label for="username">Usuario</label>
                    <input type="text" id="username" name="username" required placeholder="usuario123">
                </div>
                
                <div class="form-group">
                    <label for="full_name">Nombre Completo</label>
                    <input type="text" id="full_name" name="full_name" required placeholder="Juan Pérez">
                </div>
                
                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" required placeholder="••••••••" minlength="6">
                </div>
                
                <div class="form-group">
                    <label for="role">Rol</label>
                    <select id="role" name="role">
                        <option value="CHOFER">Chofer</option>
                        <option value="DISPATCHER">Dispatcher</option>
                        <option value="GERENTE">Gerente</option>
                    </select>
                </div>
                
                <button type="submit" class="btn" id="submitBtn">Crear Cuenta</button>
            </form>
            
            <div class="divider">o</div>
            
            <button class="btn btn-google" id="googleBtn" type="button">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google Logo">
                Registrarse con Google
            </button>
            
            <div class="link">
                <p>¿Ya tienes cuenta? <a href="/login">Inicia Sesión</a></p>
            </div>
        </div>
    </div>

    <script>
        const API_URL = 'http://localhost:8000';
        
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const btn = document.getElementById('submitBtn');
            const alert = document.getElementById('alert');
            
            btn.disabled = true;
            btn.textContent = 'Creando...';
            
            const data = {
                email: document.getElementById('email').value,
                username: document.getElementById('username').value,
                full_name: document.getElementById('full_name').value,
                password: document.getElementById('password').value,
                role: document.getElementById('role').value
            };
            
            try {
                const response = await fetch(`${API_URL}/auth/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (response.ok) {
                    localStorage.setItem('token', result.access_token);
                    localStorage.setItem('user', JSON.stringify(result.user));
                    if (result.user && !result.user.is_totp_enabled) {
                        window.location.href = '/setup-2fa';
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    alert.textContent = result.detail || 'Error al registrar';
                    alert.className = 'alert alert-error';
                    alert.classList.remove('hidden');
                }
            } catch (error) {
                alert.textContent = 'Error de conexión';
                alert.className = 'alert alert-error';
                alert.classList.remove('hidden');
            }
            
            btn.disabled = false;
            btn.textContent = 'Crear Cuenta';
        });
        
        if (localStorage.getItem('token')) {
            const user = JSON.parse(localStorage.getItem('user') || '{}');
            if (user && !user.is_totp_enabled) {
                window.location.href = '/setup-2fa';
            } else {
                window.location.href = '/dashboard';
            }
        }
        
        // Lógica para Google Register
        document.getElementById('googleBtn').addEventListener('click', () => {
            console.log('Botón de Google clickeado. Requiere inicializar el SDK de Google.');
            alert('Esta es la interfaz funcional. Para que Google te registre, debes agregar el Client ID proporcionado por Google Cloud Console en el archivo .env e inicializar el script de Google (GSI). ¡El backend (google_auth.py) ya está listo para recibir el token y crear tu cuenta!');
        });
    </script>
</body>
</html>
</file>


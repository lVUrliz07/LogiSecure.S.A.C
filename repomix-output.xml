class RutaUpdate(BaseModel):
    origen: Optional[str] = Field(None, min_length=1, max_length=255)
    destino: Optional[str] = Field(None, min_length=1, max_length=255)
    descripcion: Optional[str] = Field(None, max_length=500)
    estado: Optional[str] = Field(None, max_length=50)
    distancia_km: Optional[float] = Field(None, ge=0)
    hora_salida: Optional[datetime] = None
    hora_llegada: Optional[datetime] = None


class RutaResponse(BaseModel):
    id: int
    chofer_id: int
    origen: str
    destino: str
    descripcion: Optional[str]
    estado: str
    distancia_km: Optional[float]
    hora_salida: Optional[datetime]
    hora_llegada: Optional[datetime]
    created_at: datetime

    class Config:
        from_attributes = True


class SensitiveDataResponse(BaseModel):
    costo_real: float
    margen_ganancia: float
    clientes_vip: list[str]
    combustible_extra_en_ruta: bool
    notas_confidenciales: str
</file>

<file path="app/static/style.css">
:root {
    --primary-blue: #1e3a8a;
    --secondary-blue: #3b82f6;
    --light-blue: #60a5fa;
    --turquoise: #14b8a6;
    --light-turquoise: #5eead4;
    --white: #ffffff;
    --light-gray: #f0f9ff;
    --dark-gray: #374151;
    --error: #ef4444;
    --success: #22c55e;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background: linear-gradient(135deg, var(--light-blue) 0%, var(--light-turquoise) 100%);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
}

.container {
    background: var(--white);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(30, 58, 138, 0.3);
    width: 100%;
    max-width: 450px;
    overflow: hidden;
}

.header {
    background: var(--primary-blue);
    padding: 30px;
    text-align: center;
}

.header h1 {
    color: var(--white);
    font-size: 2rem;
    margin-bottom: 5px;
}

.header p {
    color: var(--light-turquoise);
    font-size: 0.9rem;
}

.content {
    padding: 40px 30px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    color: var(--primary-blue);
    font-weight: 600;
    margin-bottom: 8px;
    font-size: 0.9rem;
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 12px 15px;
    border: 2px solid #e5e7eb;
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: var(--white);
}

.form-group input:focus,
.form-group select:focus {
    outline: none;
    border-color: var(--turquoise);
    box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.2);
}

.btn {
    width: 100%;
    padding: 14px;
    background: var(--turquoise);
    color: var(--white);
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
}

.btn:hover {
    background: var(--primary-blue);
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(20, 184, 166, 0.4);
}

.btn:disabled {
    background: #9ca3af;
    cursor: not-allowed;
    transform: none;
}

.btn-google {
    background: var(--white);
    color: var(--dark-gray);
    border: 2px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.btn-google:hover {
    background: #f9fafb;
    border-color: #d1d5db;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
}

.btn-google img {
    width: 20px;
    height: 20px;
}

.divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 20px 0;
    color: #9ca3af;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid #e5e7eb;
}

.divider::before {
    margin-right: .25em;
}

.divider::after {
    margin-left: .25em;
}

.link {
    text-align: center;
    margin-top: 20px;
    color: var(--dark-gray);
}

.link a {
    color: var(--turquoise);
    text-decoration: none;
    font-weight: 600;
}

.link a:hover {
    text-decoration: underline;
}

.alert {
    padding: 12px 15px;
    border-radius: 10px;
    margin-bottom: 20px;
    font-size: 0.9rem;
}

.alert-error {
    background: #fef2f2;
    color: var(--error);
    border: 1px solid #fecaca;
}

.alert-success {
    background: #f0fdf4;
    color: var(--success);
    border: 1px solid #bbf7d0;
}

.hidden {
    display: none;
}

.role-badge {
    display: inline-block;
    padding: 5px 12px;
    background: var(--light-blue);
    color: var(--white);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
}

@media (max-width: 480px) {
    .container {
        border-radius: 15px;
    }
    
    .header {
        padding: 20px;
    }
    
    .header h1 {
        font-size: 1.5rem;
    }
    
    .content {
        padding: 25px 20px;
    }
}
</file>


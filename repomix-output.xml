<body>
    <div class="container">
        <div class="header">
            <h1>🛡️ Configurar Seguridad 2FA</h1>
            <p>Configura o reconfigura el Autenticador de Google en tu cuenta de LogiSecure.</p>
            <p id="statusMsg" style="color: #f59e0b; font-size: 0.85rem;"></p>
        </div>
        
        <div id="totpSetupArea">
            <button class="btn-small" id="setupTotpBtn" onclick="setupTotp()">Generar Código QR</button>
            
            <div id="totpVerifyArea" style="display:none;">
                <div class="content-grid">
                    <div class="setup-card">
                        <h3>📱 Escanea con Google Authenticator</h3>
                        <div id="qrcode"></div>
                    </div>
                    
                    <div class="setup-card">
                        <h3>🔑 ¿No funciona el QR?</h3>
                        <p style="color: #cbd5e1; margin: 0 0 8px 0; font-size: 0.85rem;">Ingresa esta clave manualmente:</p>
                        <div class="secret-box">
                            <span id="secretDisplay"></span>
                            <button class="copy-btn" onclick="copySecret()">Copiar</button>
                        </div>
                    </div>
                </div>
                
                <div class="input-section">
                    <h3>✅ Ingresa el código de 6 dígitos</h3>
                    <p>Después de escanear o ingresar la clave, escribe el código que aparece en tu aplicador:</p>
                    <input type="text" id="totpInput" placeholder="000000" maxlength="6" inputmode="numeric">
                    <div class="button-group">
                        <button class="btn-small submit" onclick="verifyTotp()">Verificar y Activar 2FA</button>
                        <button class="btn-small btn-logout" onclick="logout()">Volver al Login</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const API_URL = 'http://localhost:8000';
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        let currentSecret = '';
        
        if (!token) {
            window.location.href = '/login';
        }
        
        const statusMsg = document.getElementById('statusMsg');
        if (user.is_totp_enabled) {
            statusMsg.textContent = '⚠️ 2FA ya está habilitado. Al configurar uno nuevo, se deshabilitará el anterior.';
        } else {
            statusMsg.textContent = '📱 Configura tu Autenticador de Google para mayor seguridad.';
        }

        async function setupTotp() {
            try {
                const response = await fetch(`${API_URL}/auth/setup-2fa`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await response.json();
                
                if (response.ok) {
                    currentSecret = data.secret;
                    document.getElementById('setupTotpBtn').style.display = 'none';
                    document.getElementById('qrcode').innerHTML = '';
                    document.getElementById('secretDisplay').textContent = data.secret;
                    
                    try {
                        new QRCode(document.getElementById('qrcode'), {
                            text: data.provisioning_uri,
                            width: 300,
                            height: 300,
                            colorDark: '#1e293b',
                            colorLight: '#ffffff'
                        });
                    } catch (e) {
                        console.error("QR generation error:", e);
                        document.getElementById('qrcode').innerHTML = '<div style="padding:20px;text-align:center;color:#f59e0b;">⚠️ QR no disponible. Usa la clave manual abajo.</div>';
                    }
                    document.getElementById('totpVerifyArea').style.display = 'block';
                } else {
                    alert(data.detail || 'Error al iniciar configuración 2FA');
                }
            } catch (error) {
                console.error("Setup error:", error);
                alert('Error al conectar con el servidor: ' + error.message);
            }
        }

        function copySecret() {
            if (!currentSecret) return;
            navigator.clipboard.writeText(currentSecret).then(() => {
                alert('✓ Secret copiado al portapapeles');
            }).catch(err => {
                console.error('Error al copiar:', err);
            });
        }
        
        async function verifyTotp() {
            const code = document.getElementById('totpInput').value;
            if (!code || code.length !== 6 || isNaN(code)) {
                alert('⚠️ Ingrese un código de 6 dígitos válido');
                return;
            }
            try {
                const response = await fetch(`${API_URL}/auth/enable-2fa`, {
                    method: 'POST',
                    headers: { 
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ code: code })
                });
                
                if (response.ok) {
                    alert("✓ 2FA habilitado con éxito. Redirigiendo al dashboard...");
                    user.is_totp_enabled = true;
                    localStorage.setItem('user', JSON.stringify(user));
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 1500);
                } else {
                    const data = await response.json();
                    alert('✗ ' + (data.detail || 'Código incorrecto. Intente nuevamente.'));
                    document.getElementById('totpInput').value = '';
                }
            } catch (error) {
                console.error("Verify error:", error);
                alert('Error al verificar el código: ' + error.message);
            }
        }
        
        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/login';
        }
    </script>
</body>
</html>
</file>


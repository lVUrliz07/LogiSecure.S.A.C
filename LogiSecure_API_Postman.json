{
  "info": {
    "name": "LogiSecure API",
    "description": "Colección de pruebas para la API de LogiSecure - Sistema de gestión logística",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "javascript",
        "exec": [
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    var jsonData = pm.response.json();",
          "    if (jsonData.access_token) {",
          "        pm.collectionVariables.set('token', jsonData.access_token);",
          "    }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Registrar Usuario",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gerente@logisecure.com\",\n  \"username\": \"gerente1\",\n  \"password\": \"password123\",\n  \"full_name\": \"Juan Pérez\",\n  \"role\": \"GERENTE\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Iniciar Sesión",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gerente@logisecure.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Obtener Usuario Actual",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Validar Código",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/validate-code",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {

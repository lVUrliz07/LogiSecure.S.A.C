            "url": "{{baseUrl}}/users/2",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Actualizar Usuario",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/2",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Carlos García Actualizado\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Eliminar Usuario",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/2",
            "header": [
              {
                "key": "Authorization",

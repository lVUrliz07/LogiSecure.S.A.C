        {
          "name": "Actualizar Estado de Ruta",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/routes/1/status?estado=completada",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        }
      ]
    },

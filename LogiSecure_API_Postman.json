              "raw": "{\n  \"email\": \"chofer@logisecure.com\",\n  \"username\": \"chofer1\",\n  \"password\": \"password123\",\n  \"full_name\": \"Carlos García\",\n  \"role\": \"CHOFER\"\n}"
            }
          },
          "response": []
